PORT=3000
MONGO_URI=mongodb://localhost:27017/mysteryverse
JWT_SECRET=086aed239ea83497a9f6cd0231f4bb1166aba324bfa8fe0f4de611282e1b42a8
JWT_EXPIRY=1h

# ── Phase 6: AI Mystery Generator ─────────────────────────────────────────────
# URL of your running Ollama instance
OLLAMA_URL=http://localhost:11434
# Model to use (e.g. llama3, mistral, gemma2)
OLLAMA_MODEL=llama3
# Optional Bearer token if your Ollama server requires authentication
OLLAMA_API_KEY=
# Max Ollama requests per minute (client-side rate limiting)
OLLAMA_RATE_LIMIT_PER_MIN=10
# HTTP request timeout in milliseconds
OLLAMA_TIMEOUT_MS=60000
# Max retry attempts on network/rate-limit errors
OLLAMA_MAX_RETRIES=3

# Max mystery generation requests per room per minute (endpoint-level)
# Exceeding this returns HTTP 429 Too Many Requests
AI_RATE_LIMIT_PER_MINUTE=6

# TTL for game state (seconds). Default = 7 days
GAME_STATE_TTL_SECONDS=604800

# Role assignment rate limit in seconds per room. Default = 60
ROLE_ASSIGN_RATE_LIMIT=60

# ── Phase 8: AI Game Master ──────────────────────────────────────────────────
# Max AI Game Master requests per minute (client-side rate limiting)
GM_MAX_CALLS_PER_MIN=5
# Time to back off/delay in milliseconds when retrying GM calls
GM_BACKOFF_MS=5000
